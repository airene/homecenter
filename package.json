{
    "name": "homecenter",
    "private": true,
    "workspaces": [
        "fe",
        "be"
    ],
    "scripts": {
        "dev": "concurrently --kill-others \"bun run dev:be\" \"bun run dev:fe\"",
        "dev:fe": "bun run dev --filter=fe",
        "dev:be": "bun run dev --filter=be",
        "build": "bun run build --all",
        "build:fe": "bun run build --filter=fe",
        "start": "bun run dev --filter=be"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "prettier": "^3.8.4"
    }
}
