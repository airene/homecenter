{
    "name": "homecenter",
    "private": true,
    "workspaces": [
        "fe",
        "be"
    ],
    "scripts": {
        "dev": "bun run --workspaces dev",
        "dev:fe": "bun run --filter './fe' dev",
        "dev:be": "bun run --filter './be' dev",
        "build": "bun run --filter '*' build",
        "build:fe": "bun run --filter './fe' build",
        "start": "bun run --filter './be' dev"
    },
    "devDependencies": {
        "@types/bun": "^1.3.14",
        "prettier": "^3.8.4"
    }
}
