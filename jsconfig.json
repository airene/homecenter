{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": ["ESNext", "DOM", "DOM.Iterable"],
        "skipLibCheck": true,
        "checkJs": false,
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "paths": {
            "@/*": ["./be/src/*", "./fe/src/*"]
        },
        "types": ["vue", "vue-router", "bun", "bun-types"]
    },
    "exclude": ["node_modules", "dist"]
}
